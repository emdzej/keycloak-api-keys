meta {
  name: Echo
  type: http
  seq: 4
}

post {
  url: {{dotnetUrl}}/api/echo
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "message": "hello from Bruno",
    "timestamp": "2024-01-01T00:00:00Z"
  }
}

docs {
  Echoes the request body back, along with the authenticated user's subject.
  Requires a valid API key.
}
