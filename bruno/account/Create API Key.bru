meta {
  name: Create API Key
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/realms/{{realm}}/account/api-keys
  body: json
  auth: inherit
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "name": "My API Key",
    "clientId": "admin-cli",
    "expiresInDays": 30
  }
}
