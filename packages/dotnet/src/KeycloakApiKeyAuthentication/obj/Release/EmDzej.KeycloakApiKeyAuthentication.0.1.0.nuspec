    <description>ASP.NET Core authentication handler that exchanges API keys for Keycloak JWTs, populating HttpContext.User so [Authorize] and policy-based auth work without extra wiring.</description>
    <tags>keycloak api-key authentication aspnetcore middleware</tags>
    <repository type="git" url="https://github.com/emdzej/keycloak-api-keys" commit="40206817d548a86e8dc9de0f23e2cdc8f0aaa239" />
